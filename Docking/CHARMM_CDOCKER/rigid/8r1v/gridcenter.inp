* Get coordinates for docking
*

!! Read in topology and parameter file
read rtf card name "../toppar/top_all36_prot.rtf"
read param flex card name "../toppar/par_all36m_prot.prm"

read psf card name dimer.psf
read coor card name dimer.crd

coor stats sele segid P01A .and. (resid 164 .or. resid 304 .or. resid 341) -
                           .and. (type CA .or. type N .or. type O) show end

set xcen ?XAVE
set ycen ?YAVE
set zcen ?ZAVE

open unit 51 write form name "xcen"
echu 51
echo @xcen
close unit 51

open unit 52 write form name "ycen"
echu 52
echo @ycen
close unit 52

open unit 53 write form name "zcen"
echu 53
echo @zcen
close unit 53

stop
