* Run Segment Through CHARMM
*

read rtf card name toppar/top_opls_aam.inp
read param card name toppar/par_opls_aam.inp

read sequ pdb name @input.pdb

! now generate the PSF and also the IC table (SETU keyword), prot is SEGID defined by me
generate setu prot first NTER last CTER

! Handle disulfide patching!
patch disu prot 26 prot 42 setup
patch disu prot 122 prot 179 setup
patch disu prot 152 prot 158 setup
patch disu prot 169 prot 194 setup

!! Be careful if the sequence in the pdb file doesn't start from 1
!! use offset -xxx, xxx - start of sequence in pdb file
!! or use "resi" while reading coordinates

! set bomlev to -1 to avois sying on lack of hydrogen coordinates
bomlev -1
!!! read coor pdb resid name xxx.pdb ! use this if the residue numbering is not from 1
read coor pdb name @input.pdb !offset -15 
! them put bomlev back up to 0
bomlev 0

! prints out number of atoms that still have undefined coordinates.
define test select segid prot .and. ( .not. hydrogen ) .and. ( .not. init ) show end

ic para
ic fill preserve
ic build
hbuild sele all end

! check if there are unknown coordinate
define XXX sele .not. INIT show end
if ?nsel .gt. 0 stop ! ABNORMAL TERMINATION: Undefined coordinates

write psf card name swiss1.psf
write coor card name swiss1.crd
!write coor pdb name @input_charmm.pdb

!coor stat sele all end

calc cgtot = int ( ?cgtot )

stop

